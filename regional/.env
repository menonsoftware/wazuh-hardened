# Wazuh Regional Configuration
DOMAIN=connection.lan

# OpenSearch Java Options
INDEXER_JAVA_OPTS=-Xms1g -Xmx1g

# Cluster Settings
REGIONAL_CLUSTER_NAME=wazuh-regional-cluster

# Resource Limits
INDEXER_CPU_LIMIT=2.0
INDEXER_MEMORY_LIMIT=2G
INDEXER_CPU_RESERVATION=1.0
INDEXER_MEMORY_RESERVATION=1G

MANAGER_CPU_LIMIT=2.0
MANAGER_MEMORY_LIMIT=1G
MANAGER_CPU_RESERVATION=1.0
MANAGER_MEMORY_RESERVATION=512M

# Network Settings
INDEXER_PORT_1=9200
INDEXER_PORT_2=9201
INDEXER_PORT_3=9300
INDEXER_PORT_4=9301
MANAGER_PORT_TCP=1514
MANAGER_PORT_ENROLL=1515
MANAGER_PORT_API=55000

# Authentication (Admin password must be strong)
INDEXER_USER=admin
INDEXER_PASSWORD=Wazuh-SOC-2026!
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Wazuh-SOC-2026!
