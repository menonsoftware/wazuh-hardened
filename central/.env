# Wazuh Central Configuration
DOMAIN=connection.lan
DASHBOARD_FQDN=dashboard.connection.lan

# OpenSearch Java Options
SEARCHHEAD_JAVA_OPTS=-Xms2g -Xmx2g

# Cluster Settings
CENTRAL_CLUSTER_NAME=wazuh-central-cluster

# OpenSearch endpoints (TLS SAN-aligned)
OPENSEARCH_HOST_1=https://indexer1.connection.lan:9200
OPENSEARCH_HOST_2=https://indexer2.connection.lan:9201

# Service host aliases used in dashboard extra_hosts
WAZUH_MANAGER_HOST=wazuh-manager.soc
WAZUH_INDEXER_HOST=wazuh-indexer.soc
INDEXER_NODE_1_HOST=indexer1.connection.lan
INDEXER_NODE_2_HOST=indexer2.connection.lan

# Resource Limits
SEARCHHEAD_CPU_LIMIT=2.0
SEARCHHEAD_MEMORY_LIMIT=4G
SEARCHHEAD_CPU_RESERVATION=1.0
SEARCHHEAD_MEMORY_RESERVATION=2G

DASHBOARD_CPU_LIMIT=2.0
DASHBOARD_MEMORY_LIMIT=2G
DASHBOARD_CPU_RESERVATION=1.0
DASHBOARD_MEMORY_RESERVATION=1G

# Network Settings
DASHBOARD_PORT=443

# Authentication
INDEXER_USER=admin
INDEXER_PASSWORD=Wazuh-SOC-2026!
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Wazuh-SOC-2026!
